# Contact form — enquiries sent to this inbox
CONTACT_TO_EMAIL=enquiry.solvebytez@gmail.com

# Email provider: formsubmit (default, no password needed) | smtp
CONTACT_EMAIL_PROVIDER=formsubmit

# Gmail SMTP — only if CONTACT_EMAIL_PROVIDER=smtp (requires App Password, not regular password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=enquiry.solvebytez@gmail.com
SMTP_PASS=your_gmail_app_password_here
